# ============================================
# CONFIGURACIÓN SIMPLIFICADA - MySQL M1
# ============================================

# NOMBRES Y PUERTOS
MYSQL_CONTAINER_NAME=mysql_db
MYSQL_PORT=3306
MYSQL_X_PORT=33060

# CREDENCIALES (¡CAMBIA ESTAS!)
MYSQL_ROOT_PASSWORD=!N1k00905plasticbed
MYSQL_DATABASE=mydatabase
MYSQL_USER=bianquiviri
MYSQL_PASSWORD=!N1k00905arcade
MYSQL_ROOT_HOST=%

# CONFIGURACIÓN DE RED (UNA SOLA)
MYSQL_NETWORK_NAME=mysql_network
MYSQL_SUBNET=172.20.0.0/24
MYSQL_GATEWAY=172.20.0.1

# RECURSOS PARA MAC M1
MYSQL_MEMORY_LIMIT=2G
MYSQL_MEMORY_RESERVATION=512M
MYSQL_CPU_LIMIT=2.0
MYSQL_CPU_RESERVATION=0.5

# CONFIGURACIÓN MYSQL
MYSQL_CHARSET=utf8mb4
MYSQL_COLLATION=utf8mb4_unicode_ci
MYSQL_MAX_CONNECTIONS=100
MYSQL_INNODB_BUFFER_POOL_SIZE=1G
TZ=UTC

# HEALTHCHECK
MYSQL_HEALTHCHECK_TIMEOUT=20s
MYSQL_HEALTHCHECK_RETRIES=10
MYSQL_HEALTHCHECK_START_PERIOD=30s
MYSQL_HEALTHCHECK_INTERVAL=10s

# VOLÚMENES
MYSQL_DATA_VOLUME_NAME=mysql_data_volume
MYSQL_DATA_PATH=./data/mysql
MYSQL_BACKUP_PATH=./backups

# LOGS
MYSQL_LOG_MAX_SIZE=10m
MYSQL_LOG_MAX_FILES=3

# PROYECTO
COMPOSE_PROJECT_NAME=mysql_project
